# Certificados SSL
REQUESTS_CA_BUNDLE=C:\caminho\para\seu\certificado.pem
SSL_CERT_FILE=C:\caminho\para\seu\certificado.pem

# OpenAI API Configuration
OPENAI_API_KEY=sua-api-key-aqui
OPENAI_BASE_URL=https://sua-url-base-aqui
OPENAI_MODEL=bnb-gpt-5-mini

# Configurações de Segurança SSL
# ATENÇÃO: Apenas para ambiente de desenvolvimento
# NUNCA use ALLOW_INSECURE_SSL=true em produção!
# ALLOW_INSECURE_SSL=false

# Configurações opcionais
# CHUNK_SIZE=1500
# CHUNK_OVERLAP=200
# LLM_TEMPERATURE=0.1
# LOG_LEVEL=INFO
